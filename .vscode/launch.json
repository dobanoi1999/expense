{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Chrome",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:8000",
            "webRoot": "${workspaceFolder}"
        },
        {
            "name": "client",
            "cwd": "client",
            "request": "launch",
            "type": "dart",
            "webRoot": "${workspaceFolder}/client"
        },
        {
            "name": "client (profile mode)",
            "cwd": "client",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile",
            "webRoot": "${workspaceFolder}/client"
        },
        {
            "name": "client (release mode)",
            "cwd": "client",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "webRoot": "${workspaceFolder}/client"
        },
        {
            "name": "Flutter Web (Debug)",
            "cwd": "client",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "webRoot": "${workspaceFolder}/client"
        }
    ]
}